---
import { Icon } from 'astro-icon/components';

const fields = [
  { label: 'Направление', value: 'Море', done: true },
  { label: 'Количество человек', value: '3', done: true },
  { label: 'Даты', value: 'август', done: true },
  { label: 'Бюджет', value: 'уточняется', done: false },
];
---

<div class="w-full max-w-sm rounded-lg border border-border bg-card p-4 shadow-card-hover" aria-hidden="true">
  <div class="flex items-center gap-2 border-b border-border pb-3">
    <Icon name="heroicons:camera" class="h-4 w-4 text-muted-foreground" />
    <span class="text-xs font-medium text-muted-foreground">Instagram · Директ</span>
    <span class="ml-auto flex h-2 w-2 rounded-full bg-accent"></span>
  </div>

  <div class="mt-3 space-y-2">
    <div class="ml-auto max-w-[80%] rounded-lg rounded-tr-sm bg-muted px-3 py-2 text-sm text-foreground">
      Хочу куда-нибудь на море в августе, нас трое
    </div>
    <div class="mr-auto max-w-[85%] rounded-lg rounded-tl-sm bg-primary px-3 py-2 text-sm text-primary-foreground">
      Отлично! Уточню пару деталей — на какие даты ориентируетесь и какой бюджет комфортен?
    </div>
  </div>

  <div class="mt-4 rounded-md border border-border bg-background p-3">
    <p class="text-xs font-semibold text-muted-foreground">Заявка собирается</p>
    <ul class="mt-2 space-y-1.5">
      {
        fields.map((field) => (
          <li class="flex items-center justify-between text-xs">
            <span class="flex items-center gap-1.5 text-foreground">
              <Icon
                name={field.done ? 'heroicons:check-circle' : 'heroicons:ellipsis-horizontal-circle'}
                class:list={['h-3.5 w-3.5', field.done ? 'text-accent' : 'text-muted-foreground']}
              />
              {field.label}
            </span>
            <span class="text-muted-foreground">{field.value}</span>
          </li>
        ))
      }
    </ul>
  </div>
</div>
