---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Layout title="Страница не найдена — Платформа турагентства" description="Такой страницы нет.">
  <SiteHeader slot="header" />
  <section class="mx-auto max-w-6xl px-4 py-24 text-center sm:px-6">
    <p class="font-mono text-sm text-muted-foreground">404</p>
    <h1 class="mt-3 font-display text-3xl text-foreground">Страница не найдена</h1>
    <p class="mt-3 text-muted-foreground">
      Возможно, ссылка устарела. Вернитесь на <a href="/" class="text-accent underline">главную</a>
      или откройте <a href="/roadmap" class="text-accent underline">дорожную карту</a>.
    </p>
  </section>
  <SiteFooter slot="footer" />
</Layout>
