---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { Icon } from 'astro-icon/components';
---

<Layout
  title="Дорожная карта — платформа продвижения турагентства"
  description="Интерактивный план разработки: порядок сборки, зависимости, критерии готовности и текущий статус."
>
  <SiteHeader slot="header" />

  <section class="mx-auto max-w-6xl px-4 pb-24 pt-12 sm:px-6">
    <h1 class="font-display text-3xl text-foreground sm:text-4xl">Дорожная карта</h1>
    <p class="mt-3 max-w-2xl text-muted-foreground">
      Данные загружаются напрямую из репозитория разработки, поэтому статус здесь всегда
      совпадает с актуальным планом. Задачи разбиты по этапам сборки — сверху то, что делаем
      сначала, ниже то, что позже. Сайт турагентства — отдельный, независимый трек. Общий
      прогресс отражает ветку <code class="rounded-sm bg-muted px-1.5 py-0.5 font-mono text-xs">main</code> —
      если статус задачи уже продвинулся в <code class="rounded-sm bg-muted px-1.5 py-0.5 font-mono text-xs">dev</code>,
      но ещё не влит в main, на карточке появится бейдж «В тесте».
    </p>

    <!-- Quick nav -->
    <nav aria-label="Быстрый переход по этапам" class="mt-6 flex flex-wrap gap-2 text-sm">
      <a
        href="#phase-mvp"
        class="rounded-full border border-border px-3 py-1.5 text-muted-foreground transition-colors duration-200 hover:border-accent/50 hover:text-foreground"
      >
        1 · Ядро (MVP)
      </a>
      <a
        href="#phase-instagram-full"
        class="rounded-full border border-border px-3 py-1.5 text-muted-foreground transition-colors duration-200 hover:border-accent/50 hover:text-foreground"
      >
        2 · Директ
      </a>
      <a
        href="#phase-content"
        class="rounded-full border border-border px-3 py-1.5 text-muted-foreground transition-colors duration-200 hover:border-accent/50 hover:text-foreground"
      >
        3 · Контент
      </a>
      <a
        href="#phase-ads"
        class="rounded-full border border-border px-3 py-1.5 text-muted-foreground transition-colors duration-200 hover:border-accent/50 hover:text-foreground"
      >
        4 · Реклама
      </a>
      <a
        href="#phase-site"
        class="rounded-full border border-accent/40 bg-accent/5 px-3 py-1.5 font-medium text-accent transition-colors duration-200 hover:border-accent/70"
      >
        Сайт · отдельный трек
      </a>
      <a
        href="#phase-openclaw"
        class="rounded-full border border-accent/40 bg-accent/5 px-3 py-1.5 font-medium text-accent transition-colors duration-200 hover:border-accent/70"
      >
        Автоматизация (Open CLAW)
      </a>
      <a
        href="#backlog-section"
        class="rounded-full border border-border px-3 py-1.5 text-muted-foreground transition-colors duration-200 hover:border-accent/50 hover:text-foreground"
      >
        Backlog
      </a>
    </nav>

    <!-- Progress -->
    <div class="mt-8 rounded-lg border border-border bg-card p-6 shadow-card">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <p class="font-semibold text-foreground" id="progress-label">Прогресс</p>
        <p class="text-sm text-muted-foreground" id="progress-fraction"></p>
      </div>
      <div
        class="mt-3 h-3 w-full overflow-hidden rounded-sm bg-muted"
        role="progressbar"
        aria-labelledby="progress-label"
        aria-valuemin="0"
        aria-valuemax="100"
        id="progress-track"
      >
        <div
          id="progress-fill"
          class="h-full rounded-sm bg-accent transition-[width] duration-300 ease-out"
          style="width: 0%"
        >
        </div>
      </div>
      <div class="mt-3 flex flex-wrap gap-4 text-xs text-muted-foreground" id="progress-breakdown">
      </div>
      <p class="mt-3 text-xs text-muted-foreground">
        Без учёта Backlog — он вне текущего приоритета.
      </p>
    </div>

    <!-- Controls -->
    <div
      class="mt-8 flex flex-wrap items-end gap-6 rounded-lg border border-border bg-card p-6 shadow-card"
      role="group"
      aria-label="Фильтры и сортировка дорожной карты"
    >
      <label class="flex flex-col gap-1 text-sm">
        <span class="font-medium text-foreground">Трек</span>
        <select
          id="filter-track"
          class="min-w-[12rem] rounded-sm border border-border bg-background px-3 py-1 text-sm text-foreground cursor-pointer"
        >
          <option value="all">Все треки</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm">
        <span class="font-medium text-foreground">Статус</span>
        <select
          id="filter-status"
          class="min-w-[10rem] rounded-sm border border-border bg-background px-3 py-1 text-sm text-foreground cursor-pointer"
        >
          <option value="all">Любой статус</option>
        </select>
      </label>
      <label class="flex flex-col gap-1 text-sm">
        <span class="font-medium text-foreground">Сортировка внутри этапа</span>
        <select
          id="sort-order"
          class="min-w-[14rem] rounded-sm border border-border bg-background px-3 py-1 text-sm text-foreground cursor-pointer"
        >
          <option value="asc">По сложности: сначала простые</option>
          <option value="desc">По сложности: сначала сложные</option>
        </select>
      </label>
      <p class="text-sm text-muted-foreground" id="results-count"></p>
    </div>

    <!-- Loading -->
    <div id="state-loading" class="mt-8 space-y-3" aria-live="polite">
      {
        Array.from({ length: 4 }).map(() => (
          <div class="h-24 animate-pulse rounded-lg border border-border bg-card" />
        ))
      }
    </div>

    <!-- Error -->
    <div
      id="state-error"
      class="mt-8 hidden rounded-lg border border-destructive/30 bg-destructive/5 p-6 text-sm text-foreground"
      role="alert"
    >
      <p class="font-semibold">Не удалось загрузить дорожную карту.</p>
      <p class="mt-1 text-muted-foreground">
        Проверьте соединение с интернетом и попробуйте ещё раз.
      </p>
      <button
        id="retry-button"
        type="button"
        class="mt-3 inline-flex items-center gap-1 rounded-sm bg-primary px-4 py-3 text-sm font-semibold text-primary-foreground cursor-pointer"
      >
        <Icon name="heroicons:arrow-path" class="h-4 w-4" aria-hidden="true" />
        Повторить
      </button>
    </div>

    <!-- Empty (all phases empty under current filters) -->
    <div
      id="state-empty"
      class="mt-8 hidden rounded-lg border border-border bg-card p-6 text-sm text-muted-foreground"
    >
      По выбранным фильтрам задач не найдено. Попробуйте изменить трек или статус.
    </div>

    <!-- Phases: fixed build-order, top = do first -->
    <div id="phases-container" class="mt-10 space-y-14">
      <section id="phase-mvp" data-milestone="MVP" class="scroll-mt-24">
        <div class="flex flex-wrap items-center gap-3">
          <h2 class="font-display text-xl text-foreground">1 · Ядро платформы (MVP)</h2>
          <span class="rounded-sm bg-accent/10 px-2 py-1 text-xs font-semibold text-accent">
            начинаем здесь
          </span>
        </div>
        <p class="mt-2 max-w-2xl text-sm text-muted-foreground">
          Фундамент, Instagram без тяжёлого ревью (Трек A), ядро агента, заявки и аналитика.
          Даёт первую пользу быстрее всего и не блокируется проверкой Meta.
        </p>
        <p class="mt-2 text-xs text-muted-foreground" data-phase-count></p>
        <div class="mt-5 grid gap-3" data-phase-list aria-live="polite"></div>
      </section>

      <section id="phase-instagram-full" data-milestone="Полный Instagram" class="scroll-mt-24">
        <div class="flex flex-wrap items-center gap-3 border-t border-border pt-10">
          <h2 class="font-display text-xl text-foreground">2 · Директ и полный Instagram</h2>
        </div>
        <p class="mt-2 max-w-2xl text-sm text-muted-foreground">
          Личные сообщения в директе (Трек B). Требует App Review у Meta и перевода в Live —
          идёт следующим этапом, не блокируя ядро.
        </p>
        <p class="mt-2 text-xs text-muted-foreground" data-phase-count></p>
        <div class="mt-5 grid gap-3" data-phase-list aria-live="polite"></div>
      </section>

      <section id="phase-content" data-milestone="Контент" class="scroll-mt-24">
        <div class="flex flex-wrap items-center gap-3 border-t border-border pt-10">
          <h2 class="font-display text-xl text-foreground">3 · Контент и постинг</h2>
        </div>
        <p class="mt-2 max-w-2xl text-sm text-muted-foreground">
          Публикации, отложенные посты, контент-календарь и ИИ-контент-план. Публикации тоже
          требуют отдельного ревью Meta.
        </p>
        <p class="mt-2 text-xs text-muted-foreground" data-phase-count></p>
        <div class="mt-5 grid gap-3" data-phase-list aria-live="polite"></div>
      </section>

      <section id="phase-ads" data-milestone="Реклама" class="scroll-mt-24 opacity-90">
        <div class="flex flex-wrap items-center gap-3 border-t border-border pt-10">
          <h2 class="font-display text-lg text-foreground">4 · Реклама</h2>
          <span class="rounded-sm bg-muted px-2 py-1 text-xs font-medium text-muted-foreground">
            поздняя фаза
          </span>
        </div>
        <p class="mt-2 max-w-2xl text-sm text-muted-foreground">
          Marketing API — отдельная система, самый строгий ревью и подтверждение юр. лица.
          Есть смысл начинать, когда уже есть бюджет и стабильный органический рост.
        </p>
        <p class="mt-2 text-xs text-muted-foreground" data-phase-count></p>
        <div class="mt-5 grid gap-3" data-phase-list aria-live="polite"></div>
      </section>
    </div>

    <!-- Сайт турагентства — отдельный, независимый трек -->
    <section
      id="phase-site"
      data-milestone="Сайт"
      class="mt-14 scroll-mt-24 rounded-lg border border-accent/30 bg-accent/5 p-6 sm:p-8"
    >
      <div class="flex flex-wrap items-center gap-3">
        <h2 class="font-display text-xl text-foreground">Сайт турагентства</h2>
        <span class="rounded-sm bg-accent/10 px-2 py-1 text-xs font-semibold text-accent">
          независимый трек
        </span>
      </div>
      <p class="mt-2 max-w-2xl text-sm text-muted-foreground">
        Отдельный канал платформы, не Instagram. Строится в Треке A (без тяжёлого ревью Meta) и
        почти не зависит от остального плана — можно вести параллельно в любой момент, начиная
        со сбора требований заказчика.
      </p>
      <p class="mt-2 text-xs text-muted-foreground" data-phase-count></p>
      <div class="mt-5 grid gap-3" data-phase-list aria-live="polite"></div>
    </section>

    <!-- Автоматизация (Open CLAW) — браузерная автоматизация своих поверхностей -->
    <section
      id="phase-openclaw"
      data-milestone="Автоматизация (Open CLAW)"
      class="mt-14 scroll-mt-24 rounded-lg border border-accent/30 bg-accent/5 p-6 sm:p-8"
    >
      <div class="flex flex-wrap items-center gap-3">
        <h2 class="font-display text-xl text-foreground">Автоматизация (Open CLAW)</h2>
        <span class="rounded-sm bg-accent/10 px-2 py-1 text-xs font-semibold text-accent">
          независимый трек
        </span>
      </div>
      <p class="mt-2 max-w-2xl text-sm text-muted-foreground">
        Браузерная автоматизация своих поверхностей (Open CLAW / Playwright): сквозные E2E-тесты
        воронки заявок и синтетический мониторинг. Только свои поверхности — без неофициальных
        API соцсетей, а значит без риска банов и работы с чужими данными.
      </p>
      <p class="mt-2 text-xs text-muted-foreground" data-phase-count></p>
      <div class="mt-5 grid gap-3" data-phase-list aria-live="polite"></div>
    </section>

    <!-- Верификация Meta — независимый «бумажный» трек (юр. документы компании) -->
    <section
      id="phase-verification"
      data-milestone="Верификация Meta"
      class="mt-14 scroll-mt-24 rounded-lg border border-accent/30 bg-accent/5 p-6 sm:p-8"
    >
      <div class="flex flex-wrap items-center gap-3">
        <h2 class="font-display text-xl text-foreground">Верификация компании в Meta</h2>
        <span class="rounded-sm bg-accent/10 px-2 py-1 text-xs font-semibold text-accent">
          независимый трек
        </span>
      </div>
      <p class="mt-2 max-w-2xl text-sm text-muted-foreground">
        Юридическая верификация ООО в Meta (Business Verification → Access verification → App Review → Live).
        «Бумажный» трек: собрать документы компании и ID владельцев. Разблокирует автоответы на
        комментарии (CM1/CM2) и директ — идёт параллельно, не блокируя разработку.
      </p>
      <p class="mt-2 text-xs text-muted-foreground" data-phase-count></p>
      <div class="mt-5 grid gap-3" data-phase-list aria-live="polite"></div>
    </section>

    <!-- Backlog — отдельным блоком, вне текущего приоритета -->
    <div id="backlog-section" class="mt-14 hidden">
      <div class="flex items-center gap-3 border-t border-border pt-10">
        <h2 class="font-display text-xl text-foreground">Backlog</h2>
        <span class="rounded-sm bg-muted px-2 py-1 text-xs font-medium text-muted-foreground">
          на потом
        </span>
      </div>
      <p class="mt-2 max-w-2xl text-sm text-muted-foreground">
        Отложено — вернёмся к этому после MVP и остального плана. Не входит в текущий приоритет.
      </p>
      <div id="backlog-list" class="mt-6 grid gap-3" aria-live="polite"></div>
    </div>
  </section>

  <SiteFooter slot="footer" />

  <!-- Icon bank: pre-rendered at build time, cloned into cards at runtime -->
  <div class="hidden" aria-hidden="true">
    <span data-icon-for="todo"><Icon name="heroicons:ellipsis-horizontal-circle" /></span>
    <span data-icon-for="in_progress"><Icon name="heroicons:arrow-path" /></span>
    <span data-icon-for="blocked"><Icon name="heroicons:lock-closed" /></span>
    <span data-icon-for="done"><Icon name="heroicons:check-circle" /></span>
    <span data-icon-for="review"><Icon name="heroicons:shield-exclamation" /></span>
    <span data-icon-for="dev"><Icon name="heroicons:beaker" /></span>
    <span data-icon-for="dot-filled"><Icon name="heroicons:star-solid" /></span>
    <span data-icon-for="dot-empty"><Icon name="heroicons:star" /></span>
  </div>

  <template id="task-card-template">
    <article
      class="task-card rounded-lg border border-border bg-card p-6 shadow-card transition-shadow duration-200 hover:shadow-card-hover"
    >
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div class="flex items-center gap-3">
          <span
            class="task-id inline-flex items-center rounded-sm bg-muted px-3 py-1 font-mono text-xs font-semibold text-muted-foreground"
          ></span>
          <h3 class="task-title font-display text-lg text-foreground"></h3>
        </div>
        <span
          class="status-badge inline-flex items-center gap-1 rounded-sm px-3 py-1 text-xs font-semibold"
          data-status=""
        >
          <span class="status-icon-slot inline-flex h-3.5 w-3.5 [&_svg]:h-3.5 [&_svg]:w-3.5"></span>
          <span class="status-label"></span>
        </span>
      </div>

      <div class="mt-3 flex flex-wrap items-center gap-3 text-xs text-muted-foreground">
        <span class="track-chip inline-flex items-center rounded-sm border border-border px-3 py-1"
        ></span>
        <span
          class="difficulty-badge inline-flex items-center gap-1"
        >
          <span class="dots inline-flex gap-[2px] [&_svg]:h-3 [&_svg]:w-3"></span>
          <span class="difficulty-text font-medium"></span>
        </span>
        <span
          class="review-badge hidden inline-flex items-center gap-1 rounded-sm bg-status-in_progress-bg px-3 py-1 font-semibold text-status-in_progress-fg [&_svg]:h-3.5 [&_svg]:w-3.5"
        ></span>
        <span
          class="dev-badge hidden inline-flex items-center gap-1 rounded-sm bg-accent/10 px-3 py-1 font-semibold text-accent [&_svg]:h-3.5 [&_svg]:w-3.5"
          title="В main этот статус ещё не запушен — актуален только в dev"
        ></span>
      </div>

      <p class="deps-line mt-3 hidden text-xs text-muted-foreground">
        Зависит от: <span class="deps-list font-mono"></span>
      </p>

      <details class="details-block mt-3">
        <summary class="cursor-pointer text-sm font-medium text-accent">
          Подзадачи и критерий готовности
        </summary>
        <ul class="subtasks-list mt-3 list-disc space-y-1 pl-4 text-sm text-muted-foreground"
        ></ul>
        <p class="done-when mt-3 rounded-sm bg-muted p-3 text-sm text-foreground"></p>
      </details>
    </article>
  </template>

  <script>
    // main = прод-статус (что реально смёржено/задеплоено), dev = текущая работа,
    // ещё не влитая в main. Разница между ними подсвечивается бейджем «в тесте».
    const ROADMAP_URL =
      'https://raw.githubusercontent.com/chuck-uz/SMMPlatform/main/roadmap.json';
    const DEV_ROADMAP_URL =
      'https://raw.githubusercontent.com/chuck-uz/SMMPlatform/dev/roadmap.json';

    const STATUS_LABELS: Record<string, string> = {
      todo: 'Ожидает',
      in_progress: 'В работе',
      blocked: 'Заблокировано',
      done: 'Готово',
    };

    const TRACK_LABELS: Record<string, string> = {
      A: 'Instagram · Трек A',
      B: 'Instagram · Трек B',
    };

    const BACKLOG_TRACK = 'Backlog';

    function iconHtml(key: string): string {
      const el = document.querySelector(`[data-icon-for="${key}"]`);
      return el ? el.innerHTML : '';
    }

    function trackLabel(track: string): string {
      return TRACK_LABELS[track] ?? track;
    }

    function renderDots(difficulty: number): string {
      const filled = iconHtml('dot-filled');
      const empty = iconHtml('dot-empty');
      let out = '';
      for (let i = 1; i <= 5; i++) {
        out += `<span class="${i <= difficulty ? 'text-accent' : 'text-border'}">${
          i <= difficulty ? filled : empty
        }</span>`;
      }
      return out;
    }

    function buildCard(
      task: any,
      template: HTMLTemplateElement,
      devStatusById: Record<string, string>,
    ): HTMLElement {
      const node = template.content.cloneNode(true) as HTMLElement;
      const article = node.querySelector('.task-card') as HTMLElement;

      (node.querySelector('.task-id') as HTMLElement).textContent = task.id;
      (node.querySelector('.task-title') as HTMLElement).textContent = task.title;

      const statusBadge = node.querySelector('.status-badge') as HTMLElement;
      statusBadge.dataset.status = task.status;
      (node.querySelector('.status-label') as HTMLElement).textContent =
        STATUS_LABELS[task.status] ?? task.status;
      (node.querySelector('.status-icon-slot') as HTMLElement).innerHTML = iconHtml(task.status);

      (node.querySelector('.track-chip') as HTMLElement).textContent = trackLabel(task.track);

      (node.querySelector('.dots') as HTMLElement).innerHTML = renderDots(task.difficulty);
      (node.querySelector('.difficulty-text') as HTMLElement).textContent =
        `Сложность ${task.difficulty}/5`;

      const reviewBadge = node.querySelector('.review-badge') as HTMLElement;
      if (task.review) {
        reviewBadge.classList.remove('hidden');
        reviewBadge.innerHTML = `${iconHtml('review')}<span>Нужен ревью Meta</span>`;
      }

      const devBadge = node.querySelector('.dev-badge') as HTMLElement;
      const devStatus = devStatusById[task.id];
      if (devStatus && devStatus !== task.status) {
        devBadge.classList.remove('hidden');
        devBadge.innerHTML = `${iconHtml('dev')}<span>В тесте: ${STATUS_LABELS[devStatus] ?? devStatus}</span>`;
      }

      const depsLine = node.querySelector('.deps-line') as HTMLElement;
      if (task.deps && task.deps.length > 0) {
        depsLine.classList.remove('hidden');
        (node.querySelector('.deps-list') as HTMLElement).textContent = task.deps.join(', ');
      }

      const subtasksList = node.querySelector('.subtasks-list') as HTMLElement;
      (task.subtasks ?? []).forEach((subtask: string) => {
        const li = document.createElement('li');
        li.textContent = subtask;
        subtasksList.appendChild(li);
      });

      (node.querySelector('.done-when') as HTMLElement).textContent = `Готово, когда: ${task.done_when}`;

      article.dataset.track = task.track;
      article.dataset.status = task.status;
      article.dataset.difficulty = String(task.difficulty);

      return node.firstElementChild as HTMLElement;
    }

    function populateSelect(select: HTMLSelectElement, entries: [string, string][]) {
      entries.forEach(([value, label]) => {
        const option = document.createElement('option');
        option.value = value;
        option.textContent = label;
        select.appendChild(option);
      });
    }

    async function init() {
      const stateLoading = document.getElementById('state-loading')!;
      const stateError = document.getElementById('state-error')!;
      const stateEmpty = document.getElementById('state-empty')!;
      const phasesContainer = document.getElementById('phases-container')!;
      const siteSection = document.getElementById('phase-site')!;
      const openClawSection = document.getElementById('phase-openclaw')!;
      const verificationSection = document.getElementById('phase-verification')!;
      const backlogSection = document.getElementById('backlog-section')!;
      const backlogListEl = document.getElementById('backlog-list')!;
      const template = document.getElementById('task-card-template') as HTMLTemplateElement;
      const retryButton = document.getElementById('retry-button')!;

      const trackSelect = document.getElementById('filter-track') as HTMLSelectElement;
      const statusSelect = document.getElementById('filter-status') as HTMLSelectElement;
      const sortSelect = document.getElementById('sort-order') as HTMLSelectElement;
      const resultsCount = document.getElementById('results-count')!;

      const progressFill = document.getElementById('progress-fill')!;
      const progressTrack = document.getElementById('progress-track')!;
      const progressFraction = document.getElementById('progress-fraction')!;
      const progressBreakdown = document.getElementById('progress-breakdown')!;

      // Fixed build-order sections. Site is deliberately its own track, separate
      // from the sequential Instagram/content/ads phases; Backlog is handled apart.
      const phaseSections = [
        ...Array.from(phasesContainer.querySelectorAll<HTMLElement>('[data-milestone]')),
        siteSection,
        openClawSection,
        verificationSection,
      ];

      stateLoading.classList.remove('hidden');
      stateError.classList.add('hidden');
      stateEmpty.classList.add('hidden');

      let data: any;
      try {
        // no-store: пропускаем HTTP-кэш браузера, чтобы статус обновлялся быстро после пуша
        const res = await fetch(ROADMAP_URL, { cache: 'no-store' });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        data = await res.json();
      } catch (err) {
        stateLoading.classList.add('hidden');
        stateError.classList.remove('hidden');
        return;
      }

      stateLoading.classList.add('hidden');

      // dev — необязательный источник: если веток/файла ещё нет или сеть подвела,
      // просто не показываем бейджи «в тесте», без ошибки на всю страницу.
      let devStatusById: Record<string, string> = {};
      try {
        const devRes = await fetch(DEV_ROADMAP_URL, { cache: 'no-store' });
        if (devRes.ok) {
          const devData = await devRes.json();
          (devData.tasks ?? []).forEach((t: any) => {
            devStatusById[t.id] = t.status;
          });
        }
      } catch (err) {
        // тихо игнорируем — dev-статус необязателен для работы страницы
      }

      const tasks: any[] = data.tasks ?? [];
      const milestones: Record<string, string[]> = data.milestones ?? {};
      const tracks: Record<string, string> = data.tracks ?? {};

      populateSelect(
        trackSelect,
        Object.keys(tracks).map((t) => [t, trackLabel(t)]),
      );
      populateSelect(
        statusSelect,
        Object.entries(STATUS_LABELS),
      );

      function updateProgress() {
        // Backlog is explicitly outside current priority — excluded from the headline number.
        const scopeTasks = tasks.filter((t) => t.track !== BACKLOG_TRACK);
        const total = scopeTasks.length;
        const byStatus: Record<string, number> = { todo: 0, in_progress: 0, blocked: 0, done: 0 };
        scopeTasks.forEach((t) => {
          byStatus[t.status] = (byStatus[t.status] ?? 0) + 1;
        });
        const done = byStatus.done ?? 0;
        const pct = total > 0 ? Math.round((done / total) * 100) : 0;

        progressFill.style.width = `${pct}%`;
        progressTrack.setAttribute('aria-valuenow', String(pct));
        progressFraction.textContent = `${done} из ${total} задач готово (${pct}%)`;

        progressBreakdown.innerHTML = '';
        (Object.entries(byStatus) as [string, number][])
          .filter(([, count]) => count > 0)
          .forEach(([status, count]) => {
            const span = document.createElement('span');
            span.className =
              'status-badge inline-flex items-center gap-1 rounded-sm px-3 py-1';
            span.dataset.status = status;
            span.textContent = `${STATUS_LABELS[status]}: ${count}`;
            progressBreakdown.appendChild(span);
          });
      }

      function applyFilters() {
        const track = trackSelect.value;
        const status = statusSelect.value;
        const order = sortSelect.value;

        updateProgress();

        let shownTotal = 0;
        let matchedTotal = 0;

        phaseSections.forEach((section) => {
          const milestone = section.dataset.milestone as string;
          const ids = new Set(milestones[milestone] ?? []);
          const scopeTasks = tasks.filter((t) => ids.has(t.id));

          let filtered = scopeTasks.filter((t) => {
            if (track !== 'all' && t.track !== track) return false;
            if (status !== 'all' && t.status !== status) return false;
            return true;
          });
          filtered = [...filtered].sort((a, b) =>
            order === 'asc' ? a.difficulty - b.difficulty : b.difficulty - a.difficulty,
          );

          const listEl = section.querySelector('[data-phase-list]') as HTMLElement;
          const countEl = section.querySelector('[data-phase-count]') as HTMLElement;
          listEl.innerHTML = '';
          filtered.forEach((task) => listEl.appendChild(buildCard(task, template, devStatusById)));

          const doneCount = scopeTasks.filter((t) => t.status === 'done').length;
          countEl.textContent = `Показано ${filtered.length} из ${scopeTasks.length} · готово ${doneCount}`;

          section.classList.toggle('hidden', filtered.length === 0);
          shownTotal += filtered.length;
          matchedTotal += scopeTasks.length;
        });

        const backlogIds = new Set(milestones[BACKLOG_TRACK] ?? []);
        let backlogTasks = tasks.filter((t) => backlogIds.has(t.id));
        backlogTasks = backlogTasks.filter((t) => {
          if (track !== 'all' && t.track !== track) return false;
          if (status !== 'all' && t.status !== status) return false;
          return true;
        });
        backlogTasks = [...backlogTasks].sort((a, b) =>
          order === 'asc' ? a.difficulty - b.difficulty : b.difficulty - a.difficulty,
        );

        backlogListEl.innerHTML = '';
        if (backlogTasks.length === 0) {
          backlogSection.classList.add('hidden');
        } else {
          backlogSection.classList.remove('hidden');
          backlogTasks.forEach((task) => backlogListEl.appendChild(buildCard(task, template, devStatusById)));
        }
        shownTotal += backlogTasks.length;

        stateEmpty.classList.toggle('hidden', shownTotal > 0);
        resultsCount.textContent = `Показано задач: ${shownTotal} из ${tasks.length}`;
      }

      [trackSelect, statusSelect, sortSelect].forEach((el) =>
        el.addEventListener('change', applyFilters),
      );

      applyFilters();

      retryButton.addEventListener('click', () => init());
    }

    init();
  </script>
</Layout>
